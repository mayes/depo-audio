---
// Nav.astro — sticky nav with platform-aware download CTA + dropdown
---

<nav id="nav">
  <div class="nav-inner">

    <!-- Brand -->
    <a href="/" class="nav-brand" aria-label="DepoAudio home">
      <svg width="28" height="28" viewBox="0 0 38 38" fill="none" aria-hidden="true">
        <circle cx="19" cy="19" r="17.5" stroke="rgba(196,154,54,.35)" stroke-width="1.5"/>
        <rect x="7"  y="21" width="3.5" height="9"  rx="1.75" fill="rgba(196,154,54,.4)"/>
        <rect x="12" y="14" width="3.5" height="16" rx="1.75" fill="rgba(196,154,54,.68)"/>
        <rect x="17" y="8"  width="4"   height="22" rx="2"    fill="#c49a36"/>
        <rect x="23" y="14" width="3.5" height="16" rx="1.75" fill="rgba(196,154,54,.68)"/>
        <rect x="28" y="21" width="3.5" height="9"  rx="1.75" fill="rgba(196,154,54,.4)"/>
      </svg>
      <span class="nav-wordmark">DepoAudio</span>
    </a>

    <!-- Center links -->
    <ul class="nav-links" role="list">
      <li><a href="#formats">Formats</a></li>
      <li><a href="#features">Features</a></li>
      <li><a href="#library">Library</a></li>
      <li><a href="https://github.com/mayes/depo-audio" target="_blank" rel="noopener">GitHub</a></li>
    </ul>

    <!-- Right actions -->
    <div class="nav-right">
      <button class="theme-btn" id="themeBtn" aria-label="Toggle color theme">
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 15 15" fill="none">
          <path d="M13 9.5A6 6 0 015.5 2a6.5 6.5 0 107.5 7.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 15 15" fill="none" style="display:none">
          <circle cx="7.5" cy="7.5" r="2.5" stroke="currentColor" stroke-width="1.4"/>
          <line x1="7.5" y1="1"   x2="7.5" y2="3"   stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="7.5" y1="12"  x2="7.5" y2="14"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="1"   y1="7.5" x2="3"   y2="7.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="12"  y1="7.5" x2="14"  y2="7.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="3.2" y1="3.2" x2="4.6" y2="4.6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="10.4" y1="10.4" x2="11.8" y2="11.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="11.8" y1="3.2" x2="10.4" y2="4.6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="4.6" y1="10.4" x2="3.2" y2="11.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Download split button -->
      <div class="dl-group" id="dlGroup">
        <!-- Primary: platform-detected (filled in by JS) -->
        <a
          href="https://github.com/mayes/depo-audio/releases/latest"
          target="_blank"
          rel="noopener"
          class="dl-primary"
          id="dlPrimary"
        >
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M6.5 1v7M3 5.5l3.5 4 3.5-4M1 11h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span id="dlPrimaryLabel">Download</span>
        </a>

        <!-- Chevron trigger for dropdown -->
        <button class="dl-chevron" id="dlChevron" aria-label="Other platforms" aria-expanded="false" aria-haspopup="true">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- Dropdown -->
        <div class="dl-dropdown" id="dlDropdown" role="menu" aria-hidden="true">
          <div class="dl-dropdown-label">All platforms</div>
          <a href="https://github.com/mayes/depo-audio/releases/latest" target="_blank" rel="noopener" class="dl-option" id="dlMac" role="menuitem">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M10.5 7.5c0-1.8 1.5-2.7 1.5-2.7s-1.1-1.5-2.8-1.5c-1.2 0-2 .7-2.5.7-.6 0-1.4-.7-2.5-.7C2.3 3.3 1 4.7 1 6.8c0 2.8 2 5.2 3 5.2.6 0 1.2-.6 2-.6s1.3.6 2 .6c1 0 2.7-2 2.7-2s-.7-.7-1.2-2.5z" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M9 1.5c-.4.8-1.5 1.5-2.3 1.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            macOS (Apple Silicon)
            <span class="dl-option-sub">.dmg · arm64</span>
          </a>
          <a href="https://github.com/mayes/depo-audio/releases/latest" target="_blank" rel="noopener" class="dl-option" id="dlMacIntel" role="menuitem">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M10.5 7.5c0-1.8 1.5-2.7 1.5-2.7s-1.1-1.5-2.8-1.5c-1.2 0-2 .7-2.5.7-.6 0-1.4-.7-2.5-.7C2.3 3.3 1 4.7 1 6.8c0 2.8 2 5.2 3 5.2.6 0 1.2-.6 2-.6s1.3.6 2 .6c1 0 2.7-2 2.7-2s-.7-.7-1.2-2.5z" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M9 1.5c-.4.8-1.5 1.5-2.3 1.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            macOS (Intel)
            <span class="dl-option-sub">.dmg · x86_64</span>
          </a>
          <a href="https://github.com/mayes/depo-audio/releases/latest" target="_blank" rel="noopener" class="dl-option" id="dlWin" role="menuitem">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1" y="1" width="5.5" height="5.5" rx=".5" stroke="currentColor" stroke-width="1.2"/><rect x="7.5" y="1" width="5.5" height="5.5" rx=".5" stroke="currentColor" stroke-width="1.2"/><rect x="1" y="7.5" width="5.5" height="5.5" rx=".5" stroke="currentColor" stroke-width="1.2"/><rect x="7.5" y="7.5" width="5.5" height="5.5" rx=".5" stroke="currentColor" stroke-width="1.2"/></svg>
            Windows
            <span class="dl-option-sub">.msi · x64</span>
          </a>
          <div class="dl-dropdown-divider"></div>
          <a href="https://github.com/mayes/depo-audio/releases" target="_blank" rel="noopener" class="dl-option dl-option--muted" role="menuitem">
            All releases &amp; changelogs →
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
/* ── Nav shell ──────────────────────────────────────────────────── */
#nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: color-mix(in srgb, var(--bg) 88%, transparent);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.nav-inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 24px;
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 32px;
  height: 56px;
}

/* ── Brand ──────────────────────────────────────────────────────── */
.nav-brand {
  display: flex;
  align-items: center;
  gap: 9px;
  flex-shrink: 0;
  text-decoration: none;
}
.nav-wordmark {
  font-family: 'Crimson Pro', 'Palatino Linotype', Georgia, serif;
  font-size: 19px;
  font-weight: 600;
  color: var(--gold-hi);
  line-height: 1;
}

/* ── Center links ───────────────────────────────────────────────── */
.nav-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  list-style: none;
  margin: 0;
  padding: 0;
}
.nav-links a {
  font-size: 13px;
  font-weight: 500;
  color: var(--sub);
  text-decoration: none;
  transition: color .15s;
  white-space: nowrap;
}
.nav-links a:hover { color: var(--text); }

/* ── Right cluster ──────────────────────────────────────────────── */
.nav-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
  justify-content: flex-end;
}

/* ── Theme button ───────────────────────────────────────────────── */
.theme-btn {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  background: var(--panel);
  border: 1px solid var(--border);
  color: var(--text2);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color .15s, color .15s;
  flex-shrink: 0;
}
.theme-btn:hover { border-color: var(--gold); color: var(--gold); }

/* ── Download split button ──────────────────────────────────────── */
.dl-group {
  position: relative;
  display: flex;
  align-items: stretch;
  height: 34px;
}

.dl-primary {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 0 14px;
  background: var(--gold);
  color: #0b0f16;
  font-size: 13px;
  font-weight: 700;
  border-radius: 7px 0 0 7px;
  text-decoration: none;
  white-space: nowrap;
  transition: background .14s, box-shadow .14s;
  border-right: 1px solid rgba(0,0,0,.18);
}
.dl-primary:hover {
  background: var(--gold-hi);
  box-shadow: 0 2px 16px var(--gold-glow);
}

.dl-chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  background: var(--gold);
  color: #0b0f16;
  border: none;
  border-radius: 0 7px 7px 0;
  cursor: pointer;
  transition: background .14s;
  flex-shrink: 0;
}
.dl-chevron:hover { background: var(--gold-hi); }
.dl-chevron svg { transition: transform .15s; }
.dl-chevron[aria-expanded="true"] svg { transform: rotate(180deg); }

/* ── Dropdown ───────────────────────────────────────────────────── */
.dl-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  width: 240px;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 10px;
  box-shadow: 0 8px 32px rgba(0,0,0,.4);
  padding: 6px;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-6px);
  transition: opacity .14s, transform .14s;
  z-index: 300;
}
.dl-dropdown[aria-hidden="false"] {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.dl-dropdown-label {
  font-family: 'DM Mono', monospace;
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--sub);
  padding: 4px 10px 6px;
}

.dl-option {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 8px 10px;
  border-radius: 6px;
  font-size: 13px;
  color: var(--text);
  text-decoration: none;
  transition: background .1s, color .1s;
  cursor: pointer;
}
.dl-option:hover { background: var(--panel2); }
.dl-option--muted { color: var(--sub); font-size: 12px; }
.dl-option--muted:hover { color: var(--text2); }

.dl-option-sub {
  margin-left: auto;
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--sub);
  white-space: nowrap;
}

/* Highlight detected platform row */
.dl-option--detected {
  background: var(--gold-dim);
  color: var(--gold-hi);
}
.dl-option--detected .dl-option-sub { color: var(--gold); }
.dl-option--detected:hover { background: rgba(196,154,54,.22); }

.dl-dropdown-divider {
  height: 1px;
  background: var(--border);
  margin: 4px 6px;
}

/* ── Coming soon badge on primary btn ───────────────────────────── */
.dl-primary.coming-soon {
  background: var(--panel);
  color: var(--sub);
  border: 1px solid var(--border);
  cursor: default;
  box-shadow: none;
  border-right: none;
}
.dl-primary.coming-soon:hover { background: var(--panel); box-shadow: none; }
.dl-chevron.coming-soon {
  background: var(--panel);
  color: var(--sub);
  border: 1px solid var(--border);
  border-left: none;
}
.dl-chevron.coming-soon:hover { background: var(--panel2); }

/* ── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 700px) {
  .nav-links { display: none; }
  .nav-inner { grid-template-columns: auto auto; }
}
@media (max-width: 400px) {
  .nav-inner { padding: 0 16px; }
  .nav-wordmark { display: none; }
}
</style>

<script>
// ── Theme toggle ─────────────────────────────────────────────────
const btn    = document.getElementById('themeBtn');
const moon   = btn?.querySelector('.icon-moon') as HTMLElement | null;
const sun    = btn?.querySelector('.icon-sun')  as HTMLElement | null;
const html   = document.documentElement;

function applyTheme(t: string) {
  html.setAttribute('data-theme', t);
  html.style.background = t === 'light' ? '#f5f0e8' : '#0b0f16';
  if (moon && sun) {
    moon.style.display = t === 'dark'  ? '' : 'none';
    sun.style.display  = t === 'light' ? '' : 'none';
  }
  try { localStorage.setItem('da-theme', t); } catch {}
}

// Init from storage (may already be set by inline script)
try {
  const saved = localStorage.getItem('da-theme') || 'dark';
  applyTheme(saved);
} catch {}

btn?.addEventListener('click', () => {
  applyTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
});

// ── Platform detection ───────────────────────────────────────────
const RELEASES = 'https://github.com/mayes/depo-audio/releases/latest';

type Platform = 'mac-arm' | 'mac-intel' | 'windows' | 'other';

function detectPlatform(): Platform {
  const ua  = navigator.userAgent;
  const isMac = /Mac/.test(ua) && !/iPhone|iPad/.test(ua);
  const isWin = /Win/.test(ua);
  if (!isMac && !isWin) return 'other';
  if (isMac) {
    // Heuristic: M1+ is reported as Macintosh but NOT as "Intel Mac OS X" in some browsers.
    // canvas-based CPU detection is unreliable; fall back to checking for 'Apple Silicon'
    // via navigator.userAgentData if available (Chrome/Edge), else assume arm.
    const uad = (navigator as any).userAgentData;
    if (uad?.platform === 'macOS') {
      // Will be refined by getHighEntropyValues if available
      return 'mac-arm'; // default to arm; corrected async below
    }
    return 'mac-arm';
  }
  return 'windows';
}

const PRIMARY  = document.getElementById('dlPrimary') as HTMLAnchorElement;
const LABEL    = document.getElementById('dlPrimaryLabel');
const CHEVRON  = document.getElementById('dlChevron');
const MAC      = document.getElementById('dlMac');
const MAC_INTEL= document.getElementById('dlMacIntel');
const WIN      = document.getElementById('dlWin');

// Mark the currently-detected platform in the dropdown
function markDetected(p: Platform) {
  [MAC, MAC_INTEL, WIN].forEach(el => el?.classList.remove('dl-option--detected'));
  if (p === 'mac-arm')   MAC?.classList.add('dl-option--detected');
  if (p === 'mac-intel') MAC_INTEL?.classList.add('dl-option--detected');
  if (p === 'windows')   WIN?.classList.add('dl-option--detected');
}

function setPrimary(p: Platform) {
  if (!PRIMARY || !LABEL) return;
  const labels: Record<Platform, string> = {
    'mac-arm':   'Download for Mac',
    'mac-intel': 'Download for Mac',
    'windows':   'Download for Windows',
    'other':     'Download',
  };
  LABEL.textContent = labels[p];
  markDetected(p);
}

// Coming soon — disable primary button functionality
const COMING_SOON = true;   // ← flip to false on first release

if (COMING_SOON) {
  PRIMARY?.classList.add('coming-soon');
  (PRIMARY as HTMLAnchorElement).removeAttribute('href');
  if (LABEL) LABEL.textContent = 'Coming soon';
  CHEVRON?.classList.add('coming-soon');
} else {
  const platform = detectPlatform();
  setPrimary(platform);

  // Async refinement for Chrome/Edge on Apple Silicon
  const uad = (navigator as any).userAgentData;
  if (uad?.getHighEntropyValues) {
    uad.getHighEntropyValues(['architecture']).then((d: any) => {
      const refined: Platform = d.architecture === 'arm' ? 'mac-arm' : 'mac-intel';
      setPrimary(refined);
    }).catch(() => {});
  }
}

// ── Dropdown toggle ──────────────────────────────────────────────
const DROPDOWN = document.getElementById('dlDropdown');

function openDropdown() {
  DROPDOWN?.setAttribute('aria-hidden', 'false');
  CHEVRON?.setAttribute('aria-expanded', 'true');
}
function closeDropdown() {
  DROPDOWN?.setAttribute('aria-hidden', 'true');
  CHEVRON?.setAttribute('aria-expanded', 'false');
}

CHEVRON?.addEventListener('click', (e) => {
  e.stopPropagation();
  DROPDOWN?.getAttribute('aria-hidden') === 'false' ? closeDropdown() : openDropdown();
});

document.addEventListener('click', (e) => {
  if (!document.getElementById('dlGroup')?.contains(e.target as Node)) closeDropdown();
});

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeDropdown();
});
</script>
