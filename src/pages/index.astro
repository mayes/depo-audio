<style>
/* ── Hero ────────────────────────────────────────────────── */
.hero {
  min-height: 92vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 32px 60px;
  position: relative;
  overflow: hidden;
}
.hero-glow {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 800px; height: 500px;
  background: radial-gradient(ellipse, rgba(196,154,54,.07) 0%, transparent 70%);
  pointer-events: none;
}
.hero > * { position: relative; z-index: 1; }

/* Animated wave */
.hero-wave { display: flex; align-items: center; gap: 5px; height: 80px; margin-bottom: 32px; }
.wbar { width: 5px; border-radius: 3px; background: var(--gold); opacity: var(--op); animation: wa var(--dur) ease-in-out var(--delay) infinite alternate; }
@keyframes wa { from { height: calc(var(--h) * .22); } to { height: var(--h); } }

/* Hero text */
.eyebrow-sm { font-family: var(--mono); font-size: 11px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
.hero h1 { font-family: var(--serif); font-size: clamp(32px, 5.2vw, 64px); font-weight: 600; line-height: 1.1; color: var(--text); max-width: 840px; margin: 0 auto 20px; }
.hero h1 em { color: var(--gold-hi); font-style: italic; }
.hero-sub { font-size: clamp(15px, 1.8vw, 18px); color: var(--text2); max-width: 620px; margin: 0 auto 28px; line-height: 1.7; }
.hero-sub strong { color: var(--text); }

/* Coming-soon badge */
.cs-badge { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 11px; color: var(--amber); background: rgba(196,136,32,.1); border: 1px solid rgba(196,136,32,.25); padding: 5px 14px; border-radius: 20px; margin-bottom: 24px; }
.cs-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--amber); animation: pulse 1.4s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.75)} }

/* Platform badges */
.hero-badges { display: flex; align-items: center; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
.badge { font-family: var(--mono); font-size: 11px; padding: 4px 10px; border-radius: 5px; border: 1px solid var(--border); color: var(--sub); }

/* ── Download split button ────────────────────────────────── */
.dl-split { position: relative; display: inline-flex; align-items: stretch; height: 40px; }
.dl-split--lg { height: 48px; }

.dl-split__btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 0 18px;
  background: var(--gold); color: #0b0f16;
  font-size: 13px; font-weight: 700;
  border-radius: 8px 0 0 8px;
  text-decoration: none; white-space: nowrap;
  border-right: 1px solid rgba(0,0,0,.2);
  box-shadow: 0 4px 20px var(--gold-glow);
  transition: background .14s, box-shadow .14s;
}
.dl-split--lg .dl-split__btn { font-size: 15px; padding: 0 22px; border-radius: 9px 0 0 9px; }
.dl-split__btn:not(.coming-soon):hover { background: var(--gold-hi); box-shadow: 0 4px 32px var(--gold-glow); }
.dl-split__btn.coming-soon { background: var(--panel2); color: var(--sub); border-color: var(--border); box-shadow: none; cursor: default; }

.dl-split__chv {
  display: flex; align-items: center; justify-content: center;
  width: 32px; background: var(--gold); color: #0b0f16;
  border: none; border-radius: 0 8px 8px 0; cursor: pointer;
  box-shadow: 0 4px 20px var(--gold-glow);
  transition: background .14s; flex-shrink: 0;
}
.dl-split--lg .dl-split__chv { width: 38px; border-radius: 0 9px 9px 0; }
.dl-split__chv:not(.coming-soon):hover { background: var(--gold-hi); }
.dl-split__chv.coming-soon { background: var(--panel2); color: var(--sub); border: 1px solid var(--border); border-left: none; box-shadow: none; cursor: default; }
.dl-split__chv svg { transition: transform .15s; }
.dl-split__chv[aria-expanded="true"] svg { transform: rotate(180deg); }

/* Dropdown */
.dl-dd {
  position: absolute; top: calc(100% + 6px); left: 0;
  min-width: 250px; background: var(--panel);
  border: 1px solid var(--border); border-radius: 10px;
  box-shadow: 0 10px 36px rgba(0,0,0,.45);
  padding: 6px; opacity: 0; pointer-events: none;
  transform: translateY(-8px); transition: opacity .14s, transform .14s; z-index: 400;
}
.dl-dd--up { top: auto; bottom: calc(100% + 8px); box-shadow: 0 -10px 36px rgba(0,0,0,.45); transform: translateY(8px); }
.dl-dd[aria-hidden="false"] { opacity: 1; pointer-events: auto; transform: translateY(0); }
.dl-dd--up[aria-hidden="false"] { transform: translateY(0); }
.dl-dd__lbl { font-family: var(--mono); font-size: 9.5px; letter-spacing: 1px; text-transform: uppercase; color: var(--sub); padding: 4px 10px 6px; }
.dl-dd__opt { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 6px; font-size: 13px; color: var(--text); text-decoration: none; transition: background .1s; }
.dl-dd__opt:hover { background: var(--panel2); }
.dl-dd__opt--muted { color: var(--sub); font-size: 12px; }
.dl-dd__opt--detected { background: var(--gold-dim); color: var(--gold-hi); }
.dl-dd__opt--detected .dl-dd__sub { color: var(--gold); }
.dl-dd__sub { margin-left: auto; font-family: var(--mono); font-size: 10px; color: var(--sub); white-space: nowrap; }
.dl-dd__div { height: 1px; background: var(--border); margin: 4px 6px; }

/* ── Screenshot sections ─────────────────────────────────── */
.shot-section { padding: 70px 0; }
.shot-intro { max-width: 560px; margin-bottom: 40px; }
.shot-intro h2 { font-family: var(--serif); font-size: clamp(26px, 3.5vw, 42px); font-weight: 600; color: var(--text); margin-bottom: 12px; }
.shot-glow-wrap { border-radius: 12px; box-shadow: 0 0 0 1px var(--border), 0 24px 80px rgba(0,0,0,.5), 0 0 60px rgba(196,154,54,.06); overflow: hidden; }

/* ── Stats band ──────────────────────────────────────────── */
.stats-band { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 48px 0; }
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.stat { background: var(--panel); padding: 24px 20px; }
.stat-lbl { font-family: var(--mono); font-size: 10px; color: var(--sub); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
.stat-val { font-family: var(--serif); font-size: 24px; font-weight: 600; color: var(--gold-hi); margin-bottom: 6px; line-height: 1.1; }
.stat-desc { font-size: 12px; color: var(--text2); line-height: 1.45; }

/* ── Shared section scaffold ─────────────────────────────── */
.section { padding: 80px 0; }
.section--alt { background: var(--surface); }
.eyebrow { font-family: var(--mono); font-size: 11px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
.section h2, .section-title { font-family: var(--serif); font-size: clamp(26px, 3.8vw, 44px); font-weight: 600; color: var(--text); margin-bottom: 14px; line-height: 1.15; }
.section-sub { font-size: 16px; color: var(--text2); max-width: 580px; line-height: 1.65; margin-bottom: 44px; }
.ta-r { text-align: right; }

/* ── Format table ────────────────────────────────────────── */
.fmt-table { border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.fmt-head, .fmt-row { display: grid; grid-template-columns: 175px 1fr 65px 140px; gap: 14px; align-items: start; padding: 10px 20px; }
.fmt-head { background: var(--panel2); font-family: var(--mono); font-size: 10px; color: var(--sub); letter-spacing: 1px; text-transform: uppercase; border-bottom: 1px solid var(--border); }
.fmt-row { background: var(--panel); border-bottom: 1px solid var(--border2); transition: background .1s; }
.fmt-row:last-child { border-bottom: none; }
.fmt-row:hover { background: var(--panel2); }
.fmt-ext { font-family: var(--mono); font-size: 12px; color: var(--text); padding-top: 1px; }
.fmt-vendor { font-size: 12px; color: var(--text2); }
.fmt-note { display: block; font-size: 11px; color: var(--sub); margin-top: 3px; line-height: 1.4; }
.fmt-ch { font-family: var(--mono); font-size: 11px; color: var(--sub); padding-top: 2px; }
.fmt-status { font-family: var(--mono); font-size: 11px; font-weight: 600; padding-top: 2px; }
.fmt-status--supported { color: var(--green); }
.fmt-status--experimental { color: var(--amber); }
.fmt-status--encrypted { color: var(--red); }

/* ── Feature grid ────────────────────────────────────────── */
.feat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
.feat-card { background: var(--panel); border: 1px solid var(--border2); border-radius: var(--r); padding: 26px 22px; transition: border-color .15s, background .15s; }
.feat-card:hover { border-color: var(--border); background: var(--panel2); }
.feat-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--gold-dim); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
.feat-name { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 7px; }
.feat-desc { font-size: 13px; color: var(--text2); line-height: 1.6; }
.feat-desc strong { color: var(--text); }
.feat-desc code { font-family: var(--mono); font-size: 11px; background: var(--panel2); padding: 1px 5px; border-radius: 3px; color: var(--text2); }

/* ── Output format cards ─────────────────────────────────── */
.output-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
.out-card { background: var(--panel); border: 1px solid var(--border2); border-radius: var(--r); padding: 22px; transition: border-color .15s; }
.out-card:hover { border-color: var(--gold-dim); }
.out-ext { font-family: var(--mono); font-size: 22px; font-weight: 700; color: var(--gold-hi); margin-bottom: 6px; }
.out-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
.out-desc { font-size: 12px; color: var(--text2); line-height: 1.55; margin-bottom: 14px; }
.out-tag { display: inline-block; font-family: var(--mono); font-size: 10px; padding: 2px 8px; border-radius: 20px; }
.out-tag--green { background: rgba(58,158,106,.12); color: var(--green); }
.out-tag--blue  { background: rgba(74,141,224,.12); color: var(--blue); }
.out-tag--gold  { background: rgba(196,154,54,.12); color: var(--gold); }
.out-tag--amber { background: rgba(196,136,32,.12); color: var(--amber); }

/* ── Comparison table ────────────────────────────────────── */
.cmp-wrap { border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.cmp-head, .cmp-row { display: grid; grid-template-columns: 1fr 130px 130px 130px; align-items: center; padding: 10px 20px; }
.cmp-head { background: var(--panel2); font-family: var(--mono); font-size: 10px; color: var(--sub); letter-spacing: 1px; text-transform: uppercase; border-bottom: 1px solid var(--border); gap: 8px; }
.cmp-row { background: var(--panel); border-bottom: 1px solid var(--border2); gap: 8px; }
.cmp-row:last-child { border-bottom: none; }
.cmp-row:hover { background: var(--panel2); }
.cmp-cap { font-size: 13px; color: var(--text2); }
.cmp-c { text-align: center; font-size: 16px; }
.cmp-da { background: rgba(196,154,54,.04); }
.cy { color: var(--green); }
.cn { color: var(--red); opacity: .7; }
.cp { color: var(--amber); }
.cmp-footer { background: var(--panel2); padding: 8px 20px; font-family: var(--mono); font-size: 10px; color: var(--sub); border-top: 1px solid var(--border); }

/* ── Steps ───────────────────────────────────────────────── */
.steps { display: grid; grid-template-columns: repeat(4,1fr); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.step { padding: 28px 22px; background: var(--panel); border-right: 1px solid var(--border); }
.step:last-child { border-right: none; }
.step-n { font-family: var(--mono); font-size: 11px; color: var(--gold); letter-spacing: 1px; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
.step-n::after { content: ''; flex: 1; height: 1px; background: var(--gold-dim); }
.step-t { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 7px; }
.step-d { font-size: 12px; color: var(--text2); line-height: 1.55; }

/* ── Open source ─────────────────────────────────────────── */
.oss-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
.oss-p { font-size: 15px; color: var(--text2); line-height: 1.65; margin-bottom: 14px; }
.oss-p strong { color: var(--text); }
.btn-outline { display: inline-flex; align-items: center; padding: 10px 20px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; font-weight: 600; color: var(--text2); text-decoration: none; margin-top: 8px; transition: border-color .14s, color .14s; }
.btn-outline:hover { border-color: var(--text2); color: var(--text); }
.oss-facts { border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
.oss-fact { display: grid; grid-template-columns: 110px 1fr; gap: 14px; align-items: baseline; padding: 12px 18px; border-bottom: 1px solid var(--border2); background: var(--panel); transition: background .1s; }
.oss-fact:last-child { border-bottom: none; }
.oss-fact:hover { background: var(--panel2); }
.oss-lbl { font-family: var(--mono); font-size: 10px; color: var(--sub); text-transform: uppercase; letter-spacing: .5px; white-space: nowrap; }
.oss-val { font-size: 13px; color: var(--text2); line-height: 1.5; }

/* ── FAQ ─────────────────────────────────────────────────── */
.faq-container { display: grid; grid-template-columns: 260px 1fr; gap: 56px; align-items: start; }
.faq-container .section-sub { margin-bottom: 0; }
.link-gold { color: var(--gold); text-decoration: none; }
.link-gold:hover { color: var(--gold-hi); text-decoration: underline; }
.faq-list { display: flex; flex-direction: column; gap: 4px; }
.faq-item { border: 1px solid var(--border2); border-radius: 8px; background: var(--panel); overflow: hidden; transition: border-color .15s; }
.faq-item[open] { border-color: var(--border); }
.faq-item[open] .faq-chv { transform: rotate(180deg); }
.faq-q { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 18px; cursor: pointer; list-style: none; font-size: 14px; font-weight: 600; color: var(--text); user-select: none; }
.faq-q::-webkit-details-marker { display: none; }
.faq-q:hover { color: var(--text); background: var(--panel2); }
.faq-chv { flex-shrink: 0; color: var(--sub); transition: transform .2s; }
.faq-a { padding: 0 18px 16px; font-size: 13px; color: var(--text2); line-height: 1.65; border-top: 1px solid var(--border2); padding-top: 12px; }

/* ── CTA ─────────────────────────────────────────────────── */
.cta-section { padding: 100px 0; background: radial-gradient(ellipse 800px 400px at 50% 50%, rgba(196,154,54,.06) 0%, transparent 70%), var(--bg); text-align: center; }
.cta-inner { display: flex; flex-direction: column; align-items: center; gap: 0; }
.cta-section h2 { font-family: var(--serif); font-size: clamp(28px, 4vw, 48px); font-weight: 600; color: var(--text); max-width: 620px; line-height: 1.12; margin-bottom: 12px; }
.cta-sub { font-size: 16px; color: var(--text2); margin-bottom: 32px; }

/* ── Footer ──────────────────────────────────────────────── */
footer { background: var(--surface); border-top: 1px solid var(--border); padding: 28px 0; }
.footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 14px; }
.footer-brand { font-family: var(--serif); font-size: 17px; color: var(--gold-hi); margin-bottom: 4px; }
.footer-by { font-size: 12px; color: var(--sub); }
.footer-by a { color: var(--text2); text-decoration: none; transition: color .14s; }
.footer-by a:hover { color: var(--gold); }
.footer-links { display: flex; gap: 20px; }
.footer-links a { font-size: 12px; color: var(--sub); text-decoration: none; transition: color .14s; }
.footer-links a:hover { color: var(--text2); }

/* ── Responsive ──────────────────────────────────────────── */
@media (max-width: 960px) {
  .feat-grid          { grid-template-columns: 1fr 1fr; }
  .steps              { grid-template-columns: 1fr 1fr; }
  .step               { border-right: none; border-bottom: 1px solid var(--border); }
  .step:last-child    { border-bottom: none; }
  .oss-grid           { grid-template-columns: 1fr; gap: 36px; }
  .stats-grid         { grid-template-columns: 1fr 1fr; }
  .output-grid        { grid-template-columns: 1fr 1fr; }
  .cmp-head, .cmp-row { grid-template-columns: 1fr 100px 100px 100px; }
  .faq-container      { grid-template-columns: 1fr; gap: 28px; }
}
@media (max-width: 700px) {
  .fmt-head,.fmt-row  { grid-template-columns: 150px 1fr 110px; }
  .fmt-ch             { display: none; }
  .cmp-head,.cmp-row  { grid-template-columns: 1fr 80px 80px 80px; font-size: 12px; }
}
@media (max-width: 560px) {
  .hero               { padding: 60px 20px 48px; }
  .feat-grid,.output-grid { grid-template-columns: 1fr; }
  .steps              { grid-template-columns: 1fr; }
  .stats-grid         { grid-template-columns: 1fr; }
  .cmp-head,.cmp-row  { grid-template-columns: 1fr 60px 60px 60px; font-size: 11px; padding: 8px 12px; }
  .fmt-head,.fmt-row  { grid-template-columns: 1fr 1fr; }
  .ta-r               { display: none; }
  .footer-inner       { flex-direction: column; align-items: flex-start; }
  .footer-links       { flex-wrap: wrap; gap: 12px; }
}
</style>

<script>
// ── Shared dropdown factory ───────────────────────────────────
function makeDropdown(groupId: string, chevronId: string, dropdownId: string) {
  const group   = document.getElementById(groupId);
  const chevron = document.getElementById(chevronId);
  const dd      = document.getElementById(dropdownId);
  if (!chevron || !dd) return;

  function open()  { dd.setAttribute('aria-hidden','false'); chevron.setAttribute('aria-expanded','true'); }
  function close() { dd.setAttribute('aria-hidden','true');  chevron.setAttribute('aria-expanded','false'); }
  function toggle(e: Event) { e.stopPropagation(); dd.getAttribute('aria-hidden') === 'false' ? close() : open(); }

  chevron.addEventListener('click', toggle);
  document.addEventListener('click', (e) => { if (!group?.contains(e.target as Node)) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
}

makeDropdown('heroDlGroup', 'heroDlChevron', 'heroDlDropdown');
makeDropdown('ctaDlGroup',  'ctaDlChevron',  'ctaDlDropdown');

// ── Platform detection ────────────────────────────────────────
// Set to false on first real release
const COMING_SOON = true;

type Platform = 'mac-arm' | 'mac-intel' | 'windows' | 'other';

function detectPlatform(): Platform {
  const ua = navigator.userAgent;
  if (/Win/.test(ua)) return 'windows';
  if (/Mac/.test(ua) && !/iPhone|iPad/.test(ua)) return 'mac-arm'; // refined below
  return 'other';
}

const LABELS: Record<Platform, string> = {
  'mac-arm':   'Download for Mac',
  'mac-intel': 'Download for Mac',
  'windows':   'Download for Windows',
  'other':     'Download',
};

function applyPlatform(p: Platform, prefix: 'hero' | 'cta') {
  if (COMING_SOON) return;

  const primary = document.getElementById(`${prefix}DlPrimary`);
  const label   = document.getElementById(`${prefix}DlLabel`);
  const chevron = document.getElementById(`${prefix}DlChevron`);
  const mac     = document.getElementById(`${prefix === 'hero' ? 'hero' : 'cta'}Mac`);
  const macI    = document.getElementById(`${prefix === 'hero' ? 'hero' : 'cta'}MacIntel`);
  const win     = document.getElementById(`${prefix === 'hero' ? 'hero' : 'cta'}Win`);

  if (label)   label.textContent = LABELS[p];
  primary?.classList.remove('coming-soon');
  chevron?.classList.remove('coming-soon');

  [mac, macI, win].forEach(el => el?.classList.remove('dl-dd__opt--detected'));
  if (p === 'mac-arm')   mac?.classList.add('dl-dd__opt--detected');
  if (p === 'mac-intel') macI?.classList.add('dl-dd__opt--detected');
  if (p === 'windows')   win?.classList.add('dl-dd__opt--detected');
}

const platform = detectPlatform();
(['hero', 'cta'] as const).forEach(prefix => applyPlatform(platform, prefix));

// Async Intel/ARM refinement for Chrome/Edge
const uad = (navigator as any).userAgentData;
if (uad?.getHighEntropyValues) {
  uad.getHighEntropyValues(['architecture']).then((d: any) => {
    const refined: Platform = d.architecture === 'arm' ? 'mac-arm' : 'mac-intel';
    (['hero', 'cta'] as const).forEach(p => applyPlatform(refined, p));
  }).catch(() => {});
}
</script>
