              { l:'Network',        v:'Zero calls during conversion. Recordings never leave your machine.' },
              { l:'Stack',          v:'Tauri 2 · Rust · React · FFmpeg bundled per platform' },
              { l:'Installer size', v:'~10 MB (no Chromium — uses native system WebView)' },
              { l:'CI/CD',          v:'GitHub Actions — Windows .msi + macOS .dmg on every version tag' },
