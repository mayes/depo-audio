{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/libraries/js/tauri/tauri.conf.json",
  "productName": "DepoAudio",
  "version": "0.7.0",
  "identifier": "com.depoaudio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DepoAudio",
        "width": 960,
        "height": 720,
        "minWidth": 680,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/models/*"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" }
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        { "name": "binaries/ffmpeg", "sidecar": true },
        { "name": "binaries/ffprobe", "sidecar": true }
      ]
    }
  }
}
