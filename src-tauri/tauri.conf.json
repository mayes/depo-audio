{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DepoAudio",
  "version": "0.8.0",
  "identifier": "com.andrewmayes.depoaudio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DepoAudio",
        "width": 1160,
        "height": 820,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mayes/depo-audio/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_YOUR_TAURI_UPDATER_PUBLIC_KEY"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "public.app-category.music",
    "copyright": "2025 Andrew Mayes",
    "licenseFile": "installer/license.rtf",
    "resources": [
      "resources/models/dfn3_config.ini",
      "resources/models/dfn3_df_dec.onnx",
      "resources/models/dfn3_enc.onnx",
      "resources/models/dfn3_erb_dec.onnx",
      "resources/models/flashsr.onnx",
      "resources/models/silero_vad.onnx",
      "resources/models/smart-turn-v3-int8.onnx",
      "resources/models/speaker_seg_int8.onnx",
      "resources/onnxruntime/*"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "frameworks": []
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "wix": {
        "language": "en-US",
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    }
  }
}
